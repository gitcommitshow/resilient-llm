{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "examples"]
}
